<!DOCTYPE html>
<html>
  <head>
    <title>Junk Food | Josh Vince</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= favicon_link_tag asset_path("favicon-32x32.png") %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Libre+Franklin:wght@400;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "junk_food/junk_food", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-bauhaus-cream text-bauhaus-black font-junk-body">
    <div class="junk-food-container px-6 py-16">
      <div class="w-full max-w-lg">
        <h1 class="font-junk text-7xl md:text-8xl leading-none mb-2">Junk Food</h1>
        <div class="w-16 h-1.5 bg-bauhaus-red mb-6"></div>
        <p class="text-lg mb-10">
          Is the content you just consumed junk food for your brain? Name it and find out.
        </p>

        <%= form_with url: junk_food_path, method: :post, class: "space-y-5" do |f| %>
          <div>
            <label for="name" class="block text-sm font-semibold uppercase tracking-wider mb-2">What did you just read / watch / listen to?</label>
            <input
              type="text"
              name="name"
              id="name"
              required
              placeholder="e.g. A Twitter thread about AI"
              class="w-full px-4 py-3 border-3 border-bauhaus-black text-lg bg-white focus:outline-none focus:border-bauhaus-blue"
            />
          </div>

          <button
            type="submit"
            class="bauhaus-btn w-full px-6 py-4 bg-bauhaus-blue text-white text-lg font-bold uppercase tracking-wider border-3 border-bauhaus-black"
          >
            Rate it
          </button>
        <% end %>

        <% if @recent_foods.any? %>
          <div class="mt-16">
            <h2 class="font-junk text-2xl mb-6">Recent ratings</h2>
            <div class="dot-grid">
              <% @recent_foods.each do |food| %>
                <% first_cat = JunkFoodCategorisation.categories.first %>
                <% level = JunkFoodCategorisation.threshold_level(first_cat, food.score_for(first_cat)) %>
                <% dot_color = case level
                               when :high then "bg-bauhaus-red"
                               when :medium then "bg-bauhaus-orange"
                               else "bg-bauhaus-blue"
                               end %>
                <%= link_to junk_food_show_path(food), class: "dot-item" do %>
                  <div class="dot <%= dot_color %>"><%= food.score_for(first_cat) %>/<%= JunkFoodCategorisation.max_score_for(first_cat) %></div>
                  <span class="dot-label"><%= food.name %></span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>

        <div class="mt-12 text-center">
          <%= link_to "Back to site", root_path, class: "text-sm uppercase tracking-wider opacity-40 hover:opacity-100" %>
        </div>
      </div>
    </div>
  </body>
</html>
