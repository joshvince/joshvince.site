<%= turbo_frame_tag "junk_food_#{junk_food.id}" do %>
  <div class="space-y-8">
    <%= render partial: "pie_label", locals: { junk_food: junk_food } %>

    <div class="text-center">
      <% JunkFoodCategorisation.categories.each do |cat| %>
        <% score = junk_food.score_for(cat) %>
        <% max = JunkFoodCategorisation.max_score_for(cat) %>
        <% level = JunkFoodCategorisation.threshold_level(cat, score) %>
        <p class="font-junk text-3xl leading-tight">
          <%= cat.to_s.humanize %>: <%= score %>/<%= max %>
          <% if level == :high %>
            — Yep, that's junk food.
          <% elsif level == :medium %>
            — A bit junky, but not the worst.
          <% else %>
            — Pretty wholesome, actually.
          <% end %>
        </p>
      <% end %>
    </div>

    <div class="pt-2">
      <%= link_to junk_food_path,
            data: { turbo_frame: "_top" },
            class: "bauhaus-btn-inverted block w-full px-6 py-4 bg-bauhaus-black text-white text-lg font-bold uppercase tracking-wider border-3 border-bauhaus-black text-center" do %>
        Rate another
      <% end %>
    </div>
  </div>
<% end %>
