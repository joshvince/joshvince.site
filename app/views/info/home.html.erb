<% content_for :body_content do %>
  <div class="flex flex-col justify-start text-left">
    <h1 class="font-black text-5xl mb-4 text-left text-gray-800">Hi</h1>
    <p class="mb-12">Welcome. I'm a software developer who likes to write.
      This is sort of like my GeoCities page (ask your parents.)
      Take a look around to see things I've made and more about me.
      Below are a few recent highlights.</p>

    <% @feed_items.each do |item| %>
      <% partial, locals = feed_item_partial(item) %>
      <%= render partial: partial, locals: locals %>
    <% end %>
  </div>
<% end %>
